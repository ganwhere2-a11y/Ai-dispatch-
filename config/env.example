# --- APP SETTINGS ---
PORT=3000
AI_DISPATCH_PAUSED=false
ACTIVE_CONTEXT=USA
COST_PER_MILE=1.70
COMMISSION_RATE_EXISTING=0.08
COMMISSION_RATE_NEW=0.10
NEW_CARRIER_THRESHOLD_DAYS=90
MIN_RPM_REJECT=2.51
